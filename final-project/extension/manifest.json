{
  "manifest_version": 3,
  "name": "The Guardian",
  "version": "1.0",
  "description": "Filter toxic content",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["api.js", "ui.js", "youtube.js", "twitter.js", "content.js"],
      "css": ["style.css"]
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}